# Copy this file to .env and customize the values.
# These override the defaults set in nuxt.config.ts → runtimeConfig.public
#
# How the mapping works:
#   runtimeConfig.public.siteName   → NUXT_PUBLIC_SITE_NAME
#   runtimeConfig.public.siteTagline → NUXT_PUBLIC_SITE_TAGLINE
#   runtimeConfig.public.siteUrl    → NUXT_PUBLIC_SITE_URL
#
# Nuxt auto-maps: NUXT_PUBLIC_ prefix + camelCase key in SCREAMING_SNAKE_CASE

# The name displayed in the header logo and footer
NUXT_PUBLIC_SITE_NAME="My Blog"

# The tagline shown beneath the site name in the footer
NUXT_PUBLIC_SITE_TAGLINE="Thoughts on web development & code."

# The canonical base URL (no trailing slash). Used for building share links.
NUXT_PUBLIC_SITE_URL="http://localhost:3000"
